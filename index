<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="兜兜日記" />
<meta name="theme-color" content="#a8835a" />
<title>兜兜日記</title>
<style>
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: 'Noto Serif TC', 'Songti TC', serif;
    background: #f5ede0;
    color: #3d2f1f;
    -webkit-font-smoothing: antialiased;
    -webkit-tap-highlight-color: transparent;
  }
  input, textarea, button { font-family: inherit; }
  button { -webkit-appearance: none; appearance: none; }
  input[type="date"] { -webkit-appearance: none; appearance: none; }
</style>
</head>
<body>
<div id="root"></div>
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<script type="text/babel">
const { useState, useEffect } = React;

const C = {
  bg: "#f5ede0", bg2: "#ede2ce", cream: "#faf3e7", card: "#fdfaf3",
  primary: "#a8835a", primaryDark: "#8b6845", accent: "#c9a87a",
  text: "#3d2f1f", textMid: "#7a6750", textLight: "#a89880",
  border: "#e5d8c0", soft: "#f0e4d0",
};

const TABS = ["健康", "日常", "開銷", "紀念"];
const initialData = {
  health: { weights: [], medical: [], meds: [] },
  daily: [], expenses: [],
  memories: { dates: [], firsts: [], contacts: [] },
};

function loadData() {
  try {
    const saved = localStorage.getItem("doudou_data_v3");
    return saved ? JSON.parse(saved) : initialData;
  } catch { return initialData; }
}
function saveData(data) {
  try { localStorage.setItem("doudou_data_v3", JSON.stringify(data)); } catch {}
}
function today() { return new Date().toISOString().split("T")[0]; }
function daysUntil(dateStr) {
  const t = new Date(); t.setHours(0,0,0,0);
  const target = new Date(dateStr);
  target.setFullYear(t.getFullYear());
  if (target < t) target.setFullYear(t.getFullYear() + 1);
  return Math.ceil((target - t) / 86400000);
}

function App() {
  const [tab, setTab] = useState(0);
  const [data, setData] = useState(loadData);
  useEffect(() => saveData(data), [data]);
  const update = (k, v) => setData(d => ({ ...d, [k]: v }));
  return (
    <div style={{ minHeight: "100vh", background: C.bg, color: C.text, paddingBottom: 80 }}>
      <Header />
      <TabBar activeTab={tab} setActiveTab={setTab} />
      <div style={{ padding: "24px 18px" }}>
        {tab === 0 && <HealthTab data={data.health} setData={v => update("health", v)} />}
        {tab === 1 && <DailyTab data={data.daily} setData={v => update("daily", v)} />}
        {tab === 2 && <ExpenseTab data={data.expenses} setData={v => update("expenses", v)} />}
        {tab === 3 && <MemoryTab data={data.memories} setData={v => update("memories", v)} />}
      </div>
    </div>
  );
}

function Header() {
  return (
    <div style={{ background: `linear-gradient(180deg, ${C.bg2} 0%, ${C.bg} 100%)`, padding: "max(36px, env(safe-area-inset-top)) 20px 28px", textAlign: "center", borderBottom: `1px solid ${C.border}` }}>
      <div style={{ width: 96, height: 96, margin: "0 auto 14px", background: C.cream, borderRadius: "50%", border: `2px solid ${C.cream}`, boxShadow: `0 8px 24px ${C.primary}25, inset 0 0 0 4px ${C.bg}`, display: "flex", alignItems: "center", justifyContent: "center" }}>
        <svg width="84" height="84" viewBox="0 0 100 100">
          <path d="M 18 38 L 22 12 L 38 28 Z" fill="#c9a37a"/>
          <path d="M 82 38 L 78 12 L 62 28 Z" fill="#c9a37a"/>
          <path d="M 24 32 L 26 18 L 34 28 Z" fill="#e8c9a0"/>
          <path d="M 76 32 L 74 18 L 66 28 Z" fill="#e8c9a0"/>
          <ellipse cx="50" cy="55" rx="32" ry="28" fill="#e0b888"/>
          <ellipse cx="32" cy="62" rx="8" ry="5" fill="#f0d6b0" opacity="0.6"/>
          <ellipse cx="68" cy="62" rx="8" ry="5" fill="#f0d6b0" opacity="0.6"/>
          <ellipse cx="38" cy="52" rx="6" ry="7" fill="#3d2810"/>
          <ellipse cx="62" cy="52" rx="6" ry="7" fill="#3d2810"/>
          <circle cx="40" cy="49" r="1.6" fill="#fff"/>
          <circle cx="64" cy="49" r="1.6" fill="#fff"/>
          <path d="M 47 62 Q 50 65 53 62 Q 53 65 50 67 Q 47 65 47 62 Z" fill="#b8704a"/>
          <path d="M 50 67 Q 47 70 44 68" stroke="#7a4020" strokeWidth="1.4" fill="none"/>
          <path d="M 50 67 Q 53 70 56 68" stroke="#7a4020" strokeWidth="1.4" fill="none"/>
          <path d="M 50 70 Q 56 78 64 82" stroke="#d8c8b0" strokeWidth="1.8" fill="none"/>
          <path d="M 50 70 Q 44 78 38 84" stroke="#d8c8b0" strokeWidth="1.8" fill="none"/>
        </svg>
      </div>
      <h1 style={{ color: C.text, fontSize: 22, fontWeight: 500, margin: 0, letterSpacing: 8, paddingLeft: 8 }}>兜 兜 日 記</h1>
      <div style={{ display: "flex", alignItems: "center", justifyContent: "center", gap: 12, marginTop: 10 }}>
        <div style={{ width: 30, height: 1, background: C.accent }} />
        <p style={{ color: C.textMid, fontSize: 11, margin: 0, letterSpacing: 4, fontStyle: "italic" }}>叼著線的每一天</p>
        <div style={{ width: 30, height: 1, background: C.accent }} />
      </div>
    </div>
  );
}

function TabBar({ activeTab, setActiveTab }) {
  return (
    <div style={{ display: "flex", background: C.cream, borderBottom: `1px solid ${C.border}`, position: "sticky", top: 0, zIndex: 10 }}>
      {TABS.map((tab, i) => (
        <button key={tab} onClick={() => setActiveTab(i)} style={{ flex: 1, padding: "16px 4px 14px", border: "none", background: "none", color: activeTab === i ? C.primary : C.textLight, fontSize: 14, fontWeight: activeTab === i ? 600 : 400, letterSpacing: 2, position: "relative" }}>
          {tab}
          {activeTab === i && <div style={{ position: "absolute", bottom: 0, left: "50%", transform: "translateX(-50%)", width: 24, height: 2, background: C.primary }} />}
        </button>
      ))}
    </div>
  );
}

function Card({ children, style = {}, accent = false }) {
  return <div style={{ background: accent ? C.cream : C.card, borderRadius: 4, padding: 18, marginBottom: 14, border: `1px solid ${C.border}`, ...style }}>{children}</div>;
}

function Input({ label, value, onChange, type = "text", placeholder }) {
  return (
    <div style={{ marginBottom: 14 }}>
      <label style={{ fontSize: 10, color: C.textLight, display: "block", marginBottom: 6, letterSpacing: 2 }}>{label}</label>
      <input type={type} value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} style={{ width: "100%", padding: "10px 0", border: "none", borderBottom: `1px solid ${C.border}`, fontSize: 14, background: "transparent", outline: "none", color: C.text, minHeight: 40 }} />
    </div>
  );
}

function Textarea({ label, value, onChange, placeholder, rows = 3 }) {
  return (
    <div style={{ marginBottom: 14 }}>
      <label style={{ fontSize: 10, color: C.textLight, display: "block", marginBottom: 6, letterSpacing: 2 }}>{label}</label>
      <textarea value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} rows={rows} style={{ width: "100%", padding: "10px 12px", borderRadius: 4, border: `1px solid ${C.border}`, fontSize: 14, background: C.cream, outline: "none", color: C.text, resize: "vertical", lineHeight: 1.7 }} />
    </div>
  );
}

function PrimaryButton({ onClick, children }) {
  return <button onClick={onClick} style={{ background: C.primary, color: C.cream, border: "none", borderRadius: 2, padding: "14px 24px", fontSize: 13, fontWeight: 500, letterSpacing: 4, width: "100%" }}>{children}</button>;
}

function DeleteBtn({ onClick }) {
  return <button onClick={onClick} style={{ background: "none", border: "none", fontSize: 16, color: C.textLight, padding: "0 4px" }}>×</button>;
}

function SectionTitle({ title, sub }) {
  return (
    <div style={{ marginBottom: 22, textAlign: "center" }}>
      <div style={{ fontSize: 10, color: C.textLight, letterSpacing: 4, marginBottom: 6 }}>{sub}</div>
      <h2 style={{ margin: 0, fontSize: 18, color: C.text, fontWeight: 500, letterSpacing: 6 }}>{title}</h2>
      <div style={{ width: 24, height: 1, background: C.accent, margin: "10px auto 0" }} />
    </div>
  );
}

function SubTabs({ tabs, active, onChange }) {
  return (
    <div style={{ display: "flex", marginBottom: 20, borderBottom: `1px solid ${C.border}` }}>
      {tabs.map((t, i) => (
        <button key={t} onClick={() => onChange(i)} style={{ flex: 1, padding: "10px 4px 12px", border: "none", background: "transparent", color: active === i ? C.primary : C.textLight, fontSize: 12, fontWeight: active === i ? 600 : 400, letterSpacing: 2, borderBottom: active === i ? `2px solid ${C.primary}` : "2px solid transparent", marginBottom: -1 }}>{t}</button>
      ))}
    </div>
  );
}

function EmptyState({ text }) {
  return <div style={{ textAlign: "center", padding: "60px 20px", color: C.textLight }}>
    <div style={{ width: 40, height: 1, background: C.border, margin: "0 auto 20px" }} />
    <div style={{ fontSize: 13, letterSpacing: 2, fontStyle: "italic" }}>{text}</div>
  </div>;
}

function PillSelect({ label, options, value, onChange }) {
  return (
    <div style={{ marginBottom: 14 }}>
      <label style={{ fontSize: 10, color: C.textLight, display: "block", marginBottom: 8, letterSpacing: 2 }}>{label}</label>
      <div style={{ display: "flex", gap: 6, flexWrap: "wrap" }}>
        {options.map(opt => (
          <button key={opt} onClick={() => onChange(opt)} style={{ padding: "6px 14px", borderRadius: 2, border: `1px solid ${value === opt ? C.primary : C.border}`, background: value === opt ? C.primary : "transparent", color: value === opt ? C.cream : C.textMid, fontSize: 12, letterSpacing: 1 }}>{opt}</button>
        ))}
      </div>
    </div>
  );
}

function Tag({ children }) {
  return <span style={{ background: C.soft, color: C.primary, padding: "3px 10px", fontSize: 10, letterSpacing: 1.5, borderRadius: 2, fontWeight: 500 }}>{children}</span>;
}
function HealthTab({ data, setData }) {
  const [sub, setSub] = useState(0);
  return (
    <div>
      <SectionTitle title="健 康 紀 錄" sub="HEALTH" />
      <SubTabs tabs={["體重", "醫療", "用藥"]} active={sub} onChange={setSub} />
      {sub === 0 && <WeightSection data={data.weights || []} setData={v => setData({ ...data, weights: v })} />}
      {sub === 1 && <MedicalSection data={data.medical || []} setData={v => setData({ ...data, medical: v })} />}
      {sub === 2 && <MedsSection data={data.meds || []} setData={v => setData({ ...data, meds: v })} />}
    </div>
  );
}

function WeightSection({ data, setData }) {
  const [w, setW] = useState(""); const [n, setN] = useState(""); const [d, setD] = useState(today());
  const add = () => { if (!w) return; setData([{ id: Date.now(), date: d, weight: parseFloat(w), note: n }, ...data]); setW(""); setN(""); };
  const sorted = [...data].sort((a,b) => a.date.localeCompare(b.date));
  const latest = data[0], prev = data[1];
  const diff = latest && prev ? (latest.weight - prev.weight).toFixed(2) : null;
  return (
    <div>
      {latest && (
        <Card accent>
          <div style={{ textAlign: "center", marginBottom: sorted.length > 1 ? 20 : 0 }}>
            <div style={{ fontSize: 9, color: C.textLight, letterSpacing: 3, marginBottom: 8 }}>CURRENT WEIGHT</div>
            <div style={{ fontSize: 44, fontWeight: 300, color: C.text }}>{latest.weight}<span style={{ fontSize: 14, color: C.textLight, marginLeft: 4 }}>kg</span></div>
            {diff !== null && <div style={{ fontSize: 11, marginTop: 8, color: parseFloat(diff) > 0 ? "#b85a3a" : parseFloat(diff) < 0 ? "#5a8a6a" : C.textLight }}>{parseFloat(diff) > 0 ? "↑" : parseFloat(diff) < 0 ? "↓" : "—"} {Math.abs(diff)} kg</div>}
            <div style={{ fontSize: 10, color: C.textLight, marginTop: 6 }}>{latest.date}</div>
          </div>
          {sorted.length > 1 && <WeightChart data={sorted} />}
        </Card>
      )}
      <Card>
        <Input label="DATE" type="date" value={d} onChange={setD} />
        <Input label="WEIGHT (KG)" type="number" value={w} onChange={setW} placeholder="例：4.2" />
        <Input label="NOTE" value={n} onChange={setN} placeholder="今天狀況如何？" />
        <PrimaryButton onClick={add}>新 增 紀 錄</PrimaryButton>
      </Card>
      {data.map(item => (
        <Card key={item.id}>
          <div style={{ display: "flex", justifyContent: "space-between" }}>
            <div>
              <div style={{ fontSize: 22, fontWeight: 300, color: C.text }}>{item.weight} <span style={{ fontSize: 12, color: C.textLight }}>kg</span></div>
              <div style={{ fontSize: 11, color: C.textLight, marginTop: 2 }}>{item.date}</div>
              {item.note && <div style={{ fontSize: 13, color: C.textMid, marginTop: 8 }}>{item.note}</div>}
            </div>
            <DeleteBtn onClick={() => setData(data.filter(x => x.id !== item.id))} />
          </div>
        </Card>
      ))}
      {data.length === 0 && <EmptyState text="開始記錄兜兜的體重" />}
    </div>
  );
}

function WeightChart({ data }) {
  const W = 280, H = 110, P = 24;
  const ws = data.map(d => d.weight);
  const min = Math.min(...ws) - 0.2, max = Math.max(...ws) + 0.2;
  const range = max - min || 1;
  const pts = data.map((d, i) => ({
    x: P + (i / Math.max(data.length - 1, 1)) * (W - 2 * P),
    y: H - P - ((d.weight - min) / range) * (H - 2 * P),
  }));
  const path = pts.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`).join(' ');
  const area = `${path} L ${pts[pts.length-1].x} ${H - P} L ${pts[0].x} ${H - P} Z`;
  return (
    <div style={{ marginTop: 8, paddingTop: 16, borderTop: `1px solid ${C.border}` }}>
      <div style={{ fontSize: 9, color: C.textLight, marginBottom: 10, textAlign: "center", letterSpacing: 3 }}>WEIGHT TREND</div>
      <svg width="100%" height={H} viewBox={`0 0 ${W} ${H}`}>
        <defs>
          <linearGradient id="wg" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stopColor={C.primary} stopOpacity="0.25" />
            <stop offset="100%" stopColor={C.primary} stopOpacity="0" />
          </linearGradient>
        </defs>
        {[0.25,0.5,0.75].map(r => <line key={r} x1={P} y1={P + r*(H-2*P)} x2={W-P} y2={P + r*(H-2*P)} stroke={C.border} strokeDasharray="1 3" />)}
        <path d={area} fill="url(#wg)" />
        <path d={path} fill="none" stroke={C.primary} strokeWidth="1.5" />
        {pts.map((p, i) => <circle key={i} cx={p.x} cy={p.y} r="3" fill={C.cream} stroke={C.primary} strokeWidth="1.5" />)}
      </svg>
    </div>
  );
}

const MED_TYPES = ["疫苗", "看診", "結紮", "驅蟲", "健檢", "其他"];

function MedicalSection({ data, setData }) {
  const [type, setType] = useState("疫苗");
  const [name, setName] = useState(""); const [clinic, setClinic] = useState("");
  const [note, setNote] = useState(""); const [date, setDate] = useState(today());
  const [nextDate, setNextDate] = useState("");
  const add = () => { if (!name) return; setData([{ id: Date.now(), date, type, name, clinic, note, nextDate }, ...data]); setName(""); setClinic(""); setNote(""); setNextDate(""); };
  const upcoming = data.filter(d => d.nextDate && d.nextDate >= today()).sort((a,b) => a.nextDate.localeCompare(b.nextDate));
  return (
    <div>
      {upcoming.length > 0 && (
        <Card style={{ background: "#f5e8da" }}>
          <div style={{ fontSize: 9, color: C.primaryDark, letterSpacing: 3, marginBottom: 10, fontWeight: 600 }}>UPCOMING REMINDERS</div>
          {upcoming.slice(0, 3).map((item, i) => (
            <div key={item.id} style={{ display: "flex", justifyContent: "space-between", padding: "8px 0", borderBottom: i < 2 ? `1px solid ${C.border}` : "none" }}>
              <span style={{ fontSize: 13, color: C.text }}>{item.name}</span>
              <span style={{ fontSize: 12, color: C.primary }}>{item.nextDate}</span>
            </div>
          ))}
        </Card>
      )}
      <Card>
        <Input label="DATE" type="date" value={date} onChange={setDate} />
        <PillSelect label="TYPE" options={MED_TYPES} value={type} onChange={setType} />
        <Input label="ITEM" value={name} onChange={setName} placeholder="例：三合一疫苗" />
        <Input label="CLINIC" value={clinic} onChange={setClinic} placeholder="例：XX動物醫院" />
        <Input label="NEXT VISIT" type="date" value={nextDate} onChange={setNextDate} />
        <Input label="NOTE" value={note} onChange={setNote} placeholder="醫師說了什麼？" />
        <PrimaryButton onClick={add}>新 增 紀 錄</PrimaryButton>
      </Card>
      {data.map(item => (
        <Card key={item.id}>
          <div style={{ display: "flex", justifyContent: "space-between" }}>
            <div style={{ flex: 1 }}>
              <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 6 }}>
                <Tag>{item.type}</Tag>
                <span style={{ fontWeight: 500, color: C.text }}>{item.name}</span>
              </div>
              {item.clinic && <div style={{ fontSize: 12, color: C.textMid, marginTop: 4 }}>{item.clinic}</div>}
              {item.note && <div style={{ fontSize: 13, color: C.textMid, marginTop: 4 }}>{item.note}</div>}
              <div style={{ fontSize: 10, color: C.textLight, marginTop: 6 }}>{item.date}</div>
              {item.nextDate && <div style={{ fontSize: 11, color: C.primary, marginTop: 8, paddingTop: 8, borderTop: `1px dashed ${C.border}` }}>下次：{item.nextDate}</div>}
            </div>
            <DeleteBtn onClick={() => setData(data.filter(x => x.id !== item.id))} />
          </div>
        </Card>
      ))}
      {data.length === 0 && <EmptyState text="記錄兜兜的醫療歷史" />}
    </div>
  );
}

function MedsSection({ data, setData }) {
  const [name, setName] = useState(""); const [dosage, setDosage] = useState("");
  const [frequency, setFrequency] = useState(""); const [endDate, setEndDate] = useState("");
  const [note, setNote] = useState("");
  const add = () => { if (!name) return; setData([{ id: Date.now(), name, dosage, frequency, endDate, note }, ...data]); setName(""); setDosage(""); setFrequency(""); setEndDate(""); setNote(""); };
  return (
    <div>
      <Card>
        <Input label="MEDICATION" value={name} onChange={setName} placeholder="例：化毛膏" />
        <Input label="DOSAGE" value={dosage} onChange={setDosage} placeholder="例：1 cc" />
        <Input label="FREQUENCY" value={frequency} onChange={setFrequency} placeholder="例：每天早晚" />
        <Input label="END DATE" type="date" value={endDate} onChange={setEndDate} />
        <Input label="NOTE" value={note} onChange={setNote} placeholder="副作用？接受度？" />
        <PrimaryButton onClick={add}>新 增 用 藥</PrimaryButton>
      </Card>
      {data.map(item => (
        <Card key={item.id}>
          <div style={{ display: "flex", justifyContent: "space-between" }}>
            <div style={{ flex: 1 }}>
              <div style={{ fontWeight: 500, color: C.text, marginBottom: 8, fontSize: 15 }}>{item.name}</div>
              {item.dosage && <div style={{ fontSize: 12, color: C.textMid }}>劑量：{item.dosage}</div>}
              {item.frequency && <div style={{ fontSize: 12, color: C.textMid }}>頻率：{item.frequency}</div>}
              {item.endDate && <div style={{ fontSize: 12, color: C.textMid }}>至：{item.endDate}</div>}
              {item.note && <div style={{ fontSize: 12, color: C.textMid, marginTop: 8 }}>{item.note}</div>}
            </div>
            <DeleteBtn onClick={() => setData(data.filter(x => x.id !== item.id))} />
          </div>
        </Card>
      ))}
      {data.length === 0 && <EmptyState text="記錄兜兜的用藥情況" />}
    </div>
  );
}

const MOODS = [
  { e: "😺", l: "超開心" }, { e: "😸", l: "開心" }, { e: "😼", l: "平常" },
  { e: "🙀", l: "緊張" }, { e: "😾", l: "生氣" }, { e: "😿", l: "難過" },
];

function DailyTab({ data, setData }) {
  const [mood, setMood] = useState("😼");
  const [title, setTitle] = useState(""); const [content, setContent] = useState("");
  const [date, setDate] = useState(today());
  const add = () => { if (!title && !content) return; setData([{ id: Date.now(), date, mood, title, content }, ...data]); setTitle(""); setContent(""); setMood("😼"); };
  return (
    <div>
      <SectionTitle title="日 常 生 活" sub="DAILY" />
      <Card>
        <Input label="DATE" type="date" value={date} onChange={setDate} />
        <div style={{ marginBottom: 14 }}>
          <label style={{ fontSize: 10, color: C.textLight, display: "block", marginBottom: 10, letterSpacing: 2 }}>MOOD</label>
          <div style={{ display: "flex", gap: 4, flexWrap: "wrap" }}>
            {MOODS.map(m => (
              <button key={m.e} onClick={() => setMood(m.e)} style={{ padding: "10px 4px", border: `1px solid ${mood === m.e ? C.primary : C.border}`, background: mood === m.e ? C.cream : "transparent", flex: 1, minWidth: 48, display: "flex", flexDirection: "column", alignItems: "center", gap: 4, borderRadius: 2 }}>
                <span style={{ fontSize: 22 }}>{m.e}</span>
                <span style={{ fontSize: 9, color: C.textMid }}>{m.l}</span>
              </button>
            ))}
          </div>
        </div>
        <Input label="TITLE" value={title} onChange={setTitle} placeholder="例：第一次玩新玩具" />
        <Textarea label="CONTENT" value={content} onChange={setContent} placeholder="今天兜兜⋯⋯" rows={4} />
        <PrimaryButton onClick={add}>新 增 日 記</PrimaryButton>
      </Card>
      {data.map(item => (
        <Card key={item.id}>
          <div style={{ display: "flex", justifyContent: "space-between" }}>
            <div style={{ flex: 1 }}>
              <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 8 }}>
                <span style={{ fontSize: 24 }}>{item.mood}</span>
                {item.title && <span style={{ fontWeight: 500, color: C.text, fontSize: 15 }}>{item.title}</span>}
              </div>
              {item.content && <div style={{ fontSize: 13, color: C.textMid, lineHeight: 1.8, whiteSpace: "pre-wrap", paddingLeft: 12, borderLeft: `1px solid ${C.border}` }}>{item.content}</div>}
              <div style={{ fontSize: 10, color: C.textLight, marginTop: 12 }}>{item.date}</div>
            </div>
            <DeleteBtn onClick={() => setData(data.filter(x => x.id !== item.id))} />
          </div>
        </Card>
      ))}
      {data.length === 0 && <EmptyState text="記錄兜兜的日常點滴" />}
    </div>
  );
}

const EXP_CATS = [
  { name: "飼料", color: "#a8835a" }, { name: "零食", color: "#c9a87a" },
  { name: "醫療", color: "#b85a3a" }, { name: "玩具", color: "#7a9a6a" },
  { name: "用品", color: "#6a8a9a" }, { name: "其他", color: "#9a9080" },
];

function ExpenseTab({ data, setData }) {
  const [cat, setCat] = useState("飼料"); const [item, setItem] = useState("");
  const [amount, setAmount] = useState(""); const [date, setDate] = useState(today());
  const add = () => { if (!item || !amount) return; setData([{ id: Date.now(), date, category: cat, item, amount: parseInt(amount) }, ...data]); setItem(""); setAmount(""); };
  const cm = today().slice(0, 7);
  const md = data.filter(d => d.date.startsWith(cm));
  const mt = md.reduce((s, d) => s + d.amount, 0);
  const yt = data.filter(d => d.date.startsWith(today().slice(0, 4))).reduce((s, d) => s + d.amount, 0);
  const bc = EXP_CATS.map(c => ({ ...c, total: md.filter(d => d.category === c.name).reduce((s, d) => s + d.amount, 0) })).filter(c => c.total > 0);
  return (
    <div>
      <SectionTitle title="開 銷 紀 錄" sub="EXPENSE" />
      <Card accent>
        <div style={{ display: "flex", justifyContent: "space-around", textAlign: "center", marginBottom: bc.length > 0 ? 20 : 0, paddingBottom: bc.length > 0 ? 20 : 0, borderBottom: bc.length > 0 ? `1px solid ${C.border}` : "none" }}>
          <div>
            <div style={{ fontSize: 9, color: C.textLight, letterSpacing: 3, marginBottom: 6 }}>THIS MONTH</div>
            <div style={{ fontSize: 24, fontWeight: 300, color: C.text }}>${mt.toLocaleString()}</div>
          </div>
          <div style={{ width: 1, background: C.border }} />
          <div>
            <div style={{ fontSize: 9, color: C.textLight, letterSpacing: 3, marginBottom: 6 }}>THIS YEAR</div>
            <div style={{ fontSize: 24, fontWeight: 300, color: C.primary }}>${yt.toLocaleString()}</div>
          </div>
        </div>
        {bc.length > 0 && (
          <div>
            <div style={{ fontSize: 9, color: C.textLight, marginBottom: 10, letterSpacing: 3 }}>BREAKDOWN</div>
            {bc.map(c => {
              const pct = (c.total / mt) * 100;
              return (
                <div key={c.name} style={{ marginBottom: 10 }}>
                  <div style={{ display: "flex", justifyContent: "space-between", fontSize: 12, marginBottom: 4 }}>
                    <span style={{ color: C.textMid }}>{c.name}</span>
                    <span style={{ color: C.text, fontWeight: 500 }}>${c.total.toLocaleString()}</span>
                  </div>
                  <div style={{ height: 3, background: C.soft, borderRadius: 2, overflow: "hidden" }}>
                    <div style={{ width: `${pct}%`, height: "100%", background: c.color }} />
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </Card>
      <Card>
        <Input label="DATE" type="date" value={date} onChange={setDate} />
        <PillSelect label="CATEGORY" options={EXP_CATS.map(c => c.name)} value={cat} onChange={setCat} />
        <Input label="ITEM" value={item} onChange={setItem} placeholder="例：CIAO 鮪魚罐 24入" />
        <Input label="AMOUNT" type="number" value={amount} onChange={setAmount} placeholder="例：480" />
        <PrimaryButton onClick={add}>新 增 支 出</PrimaryButton>
      </Card>
      {data.map(it => {
        const c = EXP_CATS.find(x => x.name === it.category);
        return (
          <Card key={it.id}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
              <div style={{ flex: 1 }}>
                <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 4 }}>
                  <span style={{ background: (c?.color || "#999") + "1a", color: c?.color || "#999", padding: "3px 10px", fontSize: 10, borderRadius: 2 }}>{it.category}</span>
                  <span style={{ fontWeight: 500, color: C.text }}>{it.item}</span>
                </div>
                <div style={{ fontSize: 10, color: C.textLight, marginTop: 4 }}>{it.date}</div>
              </div>
              <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
                <span style={{ fontWeight: 400, color: C.text, fontSize: 16 }}>${it.amount.toLocaleString()}</span>
                <DeleteBtn onClick={() => setData(data.filter(x => x.id !== it.id))} />
              </div>
            </div>
          </Card>
        );
      })}
      {data.length === 0 && <EmptyState text="記錄兜兜的開銷" />}
    </div>
  );
}

function MemoryTab({ data, setData }) {
  const [sub, setSub] = useState(0);
  return (
    <div>
      <SectionTitle title="紀 念 與 重 要" sub="MEMORY" />
      <SubTabs tabs={["重要日期", "第一次", "聯絡人"]} active={sub} onChange={setSub} />
      {sub === 0 && <DatesSection data={data.dates || []} setData={v => setData({ ...data, dates: v })} />}
      {sub === 1 && <FirstsSection data={data.firsts || []} setData={v => setData({ ...data, firsts: v })} />}
      {sub === 2 && <ContactsSection data={data.contacts || []} setData={v => setData({ ...data, contacts: v })} />}
    </div>
  );
}

function DatesSection({ data, setData }) {
  const [name, setName] = useState(""); const [date, setDate] = useState(today()); const [type, setType] = useState("生日");
  const add = () => { if (!name) return; setData([{ id: Date.now(), name, date, type }, ...data]); setName(""); };
  const sorted = [...data].sort((a,b) => daysUntil(a.date) - daysUntil(b.date));
  return (
    <div>
      <Card>
        <Input label="NAME" value={name} onChange={setName} placeholder="例：兜兜生日" />
        <Input label="DATE" type="date" value={date} onChange={setDate} />
        <PillSelect label="TYPE" options={["生日", "領養日", "紀念日", "其他"]} value={type} onChange={setType} />
        <PrimaryButton onClick={add}>新 增 日 期</PrimaryButton>
      </Card>
      {sorted.map(item => {
        const days = daysUntil(item.date);
        return (
          <Card key={item.id}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", gap: 12 }}>
              <div style={{ flex: 1 }}>
                <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 6 }}>
                  <Tag>{item.type}</Tag>
                  <span style={{ fontWeight: 500, color: C.text }}>{item.name}</span>
                </div>
                <div style={{ fontSize: 11, color: C.textLight }}>{item.date}</div>
              </div>
              <div style={{ textAlign: "right", paddingLeft: 12, borderLeft: `1px solid ${C.border}` }}>
                <div style={{ fontSize: 9, color: C.textLight, letterSpacing: 2 }}>D-DAY</div>
                <div style={{ fontSize: 22, fontWeight: 300, color: days <= 30 ? C.primary : C.textMid }}>{days}</div>
              </div>
              <DeleteBtn onClick={() => setData(data.filter(x => x.id !== item.id))} />
            </div>
          </Card>
        );
      })}
      {data.length === 0 && <EmptyState text="記錄兜兜的重要日子" />}
    </div>
  );
}

function FirstsSection({ data, setData }) {
  const [event, setEvent] = useState(""); const [date, setDate] = useState(today()); const [note, setNote] = useState("");
  const add = () => { if (!event) return; setData([{ id: Date.now(), event, date, note }, ...data]); setEvent(""); setNote(""); };
  return (
    <div>
      <Card>
        <Input label="EVENT" value={event} onChange={setEvent} placeholder="例：第一次剪指甲" />
        <Input label="DATE" type="date" value={date} onChange={setDate} />
        <Textarea label="REACTION" value={note} onChange={setNote} placeholder="兜兜的反應如何？" rows={3} />
        <PrimaryButton onClick={add}>新 增 紀 錄</PrimaryButton>
      </Card>
      {data.map(item => (
        <Card key={item.id}>
          <div style={{ display: "flex", justifyContent: "space-between" }}>
            <div style={{ flex: 1 }}>
              <div style={{ fontSize: 9, color: C.textLight, letterSpacing: 3, marginBottom: 6 }}>FIRST TIME</div>
              <div style={{ fontWeight: 500, color: C.text, marginBottom: 6, fontSize: 15 }}>{item.event}</div>
              <div style={{ fontSize: 10, color: C.textLight, marginBottom: 10 }}>{item.date}</div>
              {item.note && <div style={{ fontSize: 13, color: C.textMid, lineHeight: 1.7, paddingLeft: 12, borderLeft: `1px solid ${C.border}`, fontStyle: "italic" }}>{item.note}</div>}
            </div>
            <DeleteBtn onClick={() => setData(data.filter(x => x.id !== item.id))} />
          </div>
        </Card>
      ))}
      {data.length === 0 && <EmptyState text="記錄兜兜的成長里程碑" />}
    </div>
  );
}

const CT_TYPES = ["獸醫", "醫院", "保母", "美容", "其他"];

function ContactsSection({ data, setData }) {
  const [type, setType] = useState("獸醫"); const [name, setName] = useState("");
  const [phone, setPhone] = useState(""); const [address, setAddress] = useState(""); const [note, setNote] = useState("");
  const add = () => { if (!name) return; setData([{ id: Date.now(), type, name, phone, address, note }, ...data]); setName(""); setPhone(""); setAddress(""); setNote(""); };
  return (
    <div>
      <Card>
        <PillSelect label="TYPE" options={CT_TYPES} value={type} onChange={setType} />
        <Input label="NAME" value={name} onChange={setName} placeholder="例：XX動物醫院" />
        <Input label="PHONE" value={phone} onChange={setPhone} placeholder="02-xxxx-xxxx" />
        <Input label="ADDRESS" value={address} onChange={setAddress} placeholder="選填" />
        <Input label="NOTE" value={note} onChange={setNote} placeholder="例：王醫師熟兜兜" />
        <PrimaryButton onClick={add}>新 增 聯 絡 人</PrimaryButton>
      </Card>
      {data.map(item => (
        <Card key={item.id}>
          <div style={{ display: "flex", justifyContent: "space-between" }}>
            <div style={{ flex: 1 }}>
              <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 8 }}>
                <Tag>{item.type}</Tag>
                <span style={{ fontWeight: 500, color: C.text }}>{item.name}</span>
              </div>
              {item.phone && <a href={`tel:${item.phone}`} style={{ display: "inline-block", color: C.primary, fontSize: 14, textDecoration: "none", fontWeight: 500, marginBottom: 6 }}>{item.phone}</a>}
              {item.address && <div style={{ fontSize: 12, color: C.textMid, marginTop: 2 }}>{item.address}</div>}
              {item.note && <div style={{ fontSize: 12, color: C.textMid, marginTop: 6, fontStyle: "italic" }}>{item.note}</div>}
            </div>
            <DeleteBtn onClick={() => setData(data.filter(x => x.id !== item.id))} />
          </div>
        </Card>
      ))}
      {data.length === 0 && <EmptyState text="緊急時刻能快速找到聯絡人" />}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
